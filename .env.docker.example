# jt-ipam — Docker Compose environment template
#
# Copy this file to .env (docker compose reads .env automatically):
#   cp .env.docker.example .env
#
# Then edit .env with your values. Secrets marked CHANGE_ME must be replaced.
# Generate strong secrets:
#   openssl rand -hex 64                    # for SECRET_KEY / AUDIT_CHAIN_GENESIS
#   openssl rand -base64 32                 # for ENCRYPTION_KEY
#   tr -dc A-Za-z0-9 < /dev/urandom | head -c 32  # for POSTGRES_PASSWORD
#
# ├── Required (no defaults)
# └── Optional (have sensible defaults)

# ── External domain (required) ──
# This domain must point at the Docker host where nginx listens on port 80/443.
# The backend and frontend use this for CSP, CORS, and redirect URLs.
APP_PUBLIC_URL=https://ipam.example.com
API_PUBLIC_URL=https://ipam.example.com
CORS_ORIGINS=https://ipam.example.com

# ── Secrets (required — replace CHANGE_ME values) ──
SECRET_KEY=CHANGE_ME__openssl_rand_hex_64_bytes
ENCRYPTION_KEY=CHANGE_ME__openssl_rand_base64_32
AUDIT_CHAIN_GENESIS=CHANGE_ME__openssl_rand_hex_64_bytes

# ── PostgreSQL (required) ──
# POSTGRES_USER and POSTGRES_DB are fixed at "jt_ipam" (matches the app default).
# Only POSTGRES_PASSWORD needs to be set here and kept consistent.
POSTGRES_PASSWORD=CHANGE_ME_postgres_password_32_chars

# ── Optional: auto-create admin on first startup ──
# On a fresh database (no admin exists), the entrypoint will create one.
# Remove these vars or set them empty after the first successful startup.
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_admin_password_12_chars_min
BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# ── Optional: Email (SMTP) ──
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=jt-ipam@localhost
# SMTP_TLS_MODE=starttls

# ── Optional: External integrations ──
# LDAP / AD, Radius, OIDC, SAML, Ollama, Graylog, etc.
# See .env.example at the project root for all available options.
