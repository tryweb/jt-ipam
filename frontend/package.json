{
  "name": "jt-ipam-frontend",
  "version": "0.4.139",
  "description": "jt-ipam — 可自架的整合型 IPAM 系統前端",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --port 5173 --host",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .vue,.ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,css,scss,json,md}\"",
    "audit": "pnpm audit --audit-level=high",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@iconoir/vue": "^7.11.0",
    "@vueuse/core": "^11.2.0",
    "axios": "^1.7.9",
    "cytoscape": "^3.30.4",
    "cytoscape-cose-bilkent": "^4.1.0",
    "naive-ui": "^2.40.1",
    "pinia": "^2.2.6",
    "qrcode": "^1.5.4",
    "vfonts": "^0.0.3",
    "vue": "^3.5.13",
    "vue-i18n": "^10.0.4",
    "vue-router": "^4.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/cytoscape": "^3.21.7",
    "@types/qrcode": "^1.5.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "~5.6.3",
    "vite": "^6.0.5",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.1.10"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9"
}
