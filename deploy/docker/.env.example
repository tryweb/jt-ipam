# jt-ipam Docker Compose env — copy to .env and fill in, or just run ./gen-env.sh.
# Do NOT commit your real .env. Secrets must be long random values (>= 32 bytes).

# ---- exposed ports on the host ----
HTTP_PORT=80
HTTPS_PORT=443
# Hostname used in the self-signed cert SAN (and what you browse to).
JT_IPAM_SERVER_NAME=localhost

# ---- public URLs / CORS (must be https) ----
# If you change HTTPS_PORT or JT_IPAM_SERVER_NAME, update these to match.
APP_PUBLIC_URL=https://localhost
API_PUBLIC_URL=https://localhost
CORS_ORIGINS=https://localhost

APP_ENV=production
APP_DEBUG=false
SESSION_COOKIE_SECURE=true

# ---- TLS: nginx (the web container) terminates HTTPS; backend stays plain HTTP internally ----
# Keep BACKEND_BIND_HOST as loopback: the app's security check requires it in nginx mode.
# (The container's uvicorn actually binds 0.0.0.0 via the image CMD so the web container can
#  reach it — but port 8000 is NOT published to the host, only on the compose network.)
BACKEND_TLS_MODE=nginx
BACKEND_BIND_HOST=127.0.0.1
BACKEND_BIND_PORT=8000

# ---- secrets (REQUIRED) — generate with ./gen-env.sh or openssl ----
# openssl rand -hex 64
SECRET_KEY=__CHANGE_ME__
# openssl rand -base64 32
ENCRYPTION_KEY=__CHANGE_ME__
# openssl rand -hex 32
AUDIT_CHAIN_GENESIS=__CHANGE_ME__

# ---- database (service name 'postgres' on the compose network) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jt_ipam
POSTGRES_USER=jt_ipam
# openssl rand -hex 24
POSTGRES_PASSWORD=__CHANGE_ME__

# ---- redis (service name 'redis') ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- background sync loop interval (seconds) ----
SYNC_INTERVAL_SECONDS=300

# ---- first admin (optional): if set, created on first startup ----
# Leave PASSWORD empty to create the admin yourself later via the CLI.
JT_IPAM_ADMIN_USERNAME=admin
JT_IPAM_ADMIN_EMAIL=admin@example.com
JT_IPAM_ADMIN_PASSWORD=
# set to 1 to reset the admin password to JT_IPAM_ADMIN_PASSWORD on every start
JT_IPAM_ADMIN_FORCE=
